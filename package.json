{
  "name": "hiroba-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Internal platform engineering framework using Crossplane and CDK8s",
  "engines": {
    "node": ">=20.0.0"
  },
  "workspaces": [
    "packages/*",
    "consumer-sdk/typescript",
    "examples/*",
    "tools/*"
  ],
  "scripts": {
    "lint": "eslint '**/*.{ts,tsx,js}'",
    "lint:fix": "eslint '**/*.{ts,tsx,js}' --fix",
    "format": "prettier --write '**/*.{ts,tsx,js,json,md,yaml,yml}'",
    "build": "npm run build -w @7k-hiroba/shared && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:e2e": "npm run test:e2e --workspaces --if-present",
    "synth": "npm run synth --workspaces --if-present",
    "validate": "npm run validate --workspaces --if-present",
    "package": "npm run package --workspaces --if-present",
    "publish": "npm run publish --workspaces --if-present",
    "prepare": "husky",
    "gen:contract": "ts-node scripts/gen-contract.ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cdk8s-cli": "^2.198.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
