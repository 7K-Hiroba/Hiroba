{
  "name": "@7k-hiroba/object-storage",
  "version": "3.0.0",
  "description": "Agnostic object-storage primitive with provider toggle (S3 / Garage / GCS / Azure Blob). Reconciled by the central orchestrator function (ADR 007).",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/7K-Hiroba/Hiroba.git",
    "directory": "packages/object-storage"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "synth": "cdk8s synth",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "pretest:e2e": "npm run build -w @7k-hiroba/shared",
    "test:e2e": "jest --testPathPattern=test/e2e --passWithNoTests",
    "validate": "../../scripts/render-validate.sh packages/object-storage",
    "package": "cp dist/*.yaml package/ && crossplane build configuration package/"
  },
  "dependencies": {
    "@7k-hiroba/shared": "*",
    "cdk8s": "^2.68.0",
    "constructs": "^10.3.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "cdk8s-cli": "^2.198.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
