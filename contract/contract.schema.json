{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Hiroba Platform Contract",
  "description": "Single source of truth for platform API versions, profiles, provider vocabularies and connection-secret contracts. Codegen emits TypeScript (packages/shared/src/contract.gen.ts) and Go (functions/platform/internal/contract/contract.gen.go) from this file. Run `npm run gen:contract` after editing.",
  "type": "object",
  "required": ["apiGroup", "apiVersion", "orchestratorFunction", "labels", "profiles", "products"],
  "additionalProperties": false,
  "properties": {
    "apiGroup": { "type": "string", "pattern": "^[a-z0-9.]+\\.[a-z]+$" },
    "apiVersion": { "type": "string", "pattern": "^v[0-9]+(alpha|beta)?[0-9]*$" },
    "orchestratorFunction": { "type": "string" },
    "labels": {
      "type": "object",
      "required": ["team", "costCenter", "stack"],
      "additionalProperties": false,
      "properties": {
        "team": { "type": "string" },
        "costCenter": { "type": "string" },
        "stack": { "type": "string" }
      }
    },
    "profiles": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "instanceClass",
          "multiAZ",
          "backupRetentionDays",
          "deletionProtection",
          "storageEncrypted",
          "deletionPolicy"
        ],
        "additionalProperties": false,
        "properties": {
          "instanceClass": { "type": "string" },
          "multiAZ": { "type": "boolean" },
          "backupRetentionDays": { "type": "integer", "minimum": 0 },
          "deletionProtection": { "type": "boolean" },
          "storageEncrypted": { "type": "boolean" },
          "deletionPolicy": { "type": "string", "enum": ["Delete", "Orphan"] }
        }
      }
    },
    "products": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "plural", "singular", "providers", "defaultProvider", "connectionKeys"],
        "additionalProperties": false,
        "properties": {
          "kind": { "type": "string" },
          "plural": { "type": "string" },
          "singular": { "type": "string" },
          "providers": { "type": "array", "minItems": 1, "items": { "type": "string" } },
          "defaultProvider": { "type": "string" },
          "defaultRegion": { "type": "string" },
          "connectionKeys": { "type": "array", "minItems": 1, "items": { "type": "string" } }
        }
      }
    }
  }
}
