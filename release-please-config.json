{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": true,
  "tag-separator": "-",
  "separate-pull-requests": true,
  "pull-request-title-pattern": "chore${scope}: release${component} ${version}",
  "packages": {
    "functions/platform": {
      "package-name": "function-platform",
      "release-type": "simple",
      "bump-minor-pre-major": true,
      "changelog-path": "CHANGELOG.md"
    },
    "packages/primitives": {
      "package-name": "platform-primitives",
      "release-type": "simple",
      "bump-minor-pre-major": true,
      "changelog-path": "CHANGELOG.md"
    },
    "packages/shared": {
      "package-name": "shared",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/postgres": {
      "package-name": "postgres",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/object-storage": {
      "package-name": "object-storage",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    },
    "consumer-sdk/typescript": {
      "package-name": "platform-consumer",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    },
    "tools/create-product": {
      "package-name": "create-product",
      "release-type": "node",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
