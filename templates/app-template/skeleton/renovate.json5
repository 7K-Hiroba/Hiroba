{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "separateMajorMinor": false,
  "separateMinorPatch": false,

  "customManagers": [
    {
      "customType": "regex",
      "description": "Container image references in Helm values (imageName field)",
      "managerFilePatterns": ["/helm/.+/values\\.yaml$/"],
      "matchStrings": [
        "imageName:\\s*(?<depName>[^:]+):(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Container image references in Helm values (split repository/tag form)",
      "managerFilePatterns": ["/helm/.+/values\\.yaml$/"],
      // Matches the standard Helm split-image block, tolerating intervening
      // sibling keys like `pullPolicy:` between `repository:` and `tag:`.
      // Empty tags (e.g. `tag: ""`, which falls back to .Chart.AppVersion)
      // are intentionally skipped — those are app-self-references bumped by
      // the app's release pipeline, not Renovate.
      "matchStrings": [
        "repository:\\s*[\"']?(?<depName>[a-zA-Z0-9.\\-_/:]+?)[\"']?\\s*(?:#[^\\n]*)?\\n(?:\\s*[a-zA-Z][a-zA-Z0-9]*:[^\\n]*\\n){0,5}?\\s*tag:\\s*[\"']?(?<currentValue>[a-zA-Z0-9.\\-_+]+)[\"']?"
      ],
      "datasourceTemplate": "docker"
    }
  ],

  "packageRules": [
    {
      "description": "Group Dockerfile base image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker-base-images",
      "semanticCommitType": "fix",
      "semanticCommitScope": "docker"
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "semanticCommitType": "ci"
    },
    {
      "description": "Platform chart dependency updates",
      "matchFileNames": ["helm/platform/**"],
      "semanticCommitType": "fix",
      "semanticCommitScope": "helm-platform"
    }
  ]
}
